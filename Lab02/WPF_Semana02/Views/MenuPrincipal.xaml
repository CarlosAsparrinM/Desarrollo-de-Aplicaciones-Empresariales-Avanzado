<Window x:Class="WPF_Semana02.Views.MenuPrincipal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Menú Principal" Height="400" Width="600">
    <Grid Background="White">
        <Border Background="#FF8800" Height="60" VerticalAlignment="Top" CornerRadius="0,0,20,20">
            <TextBlock Text="Menú Principal" Foreground="White" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
        </Border>
        <StackPanel Margin="40,80,40,40" Background="White" VerticalAlignment="Top">
            <Button Content="Operaciones" Background="#FF8800" Foreground="White" Height="40" FontSize="16" Margin="0,0,0,10" Click="BtnOperaciones_Click"/>
            <Button Content="Mantenimientos" Background="#FF8800" Foreground="White" Height="40" FontSize="16" Margin="0,0,0,10" Click="BtnMantenimientos_Click"/>
            <Button Content="Reportes" Background="#FF8800" Foreground="White" Height="40" FontSize="16" Click="BtnReportes_Click"/>
        </StackPanel>
    </Grid>
</Window>