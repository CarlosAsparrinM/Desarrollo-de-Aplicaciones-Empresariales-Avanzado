<Window x:Class="WPF_Semana02.Views.Productos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productos" Height="400" Width="600">
    <Grid Background="White">
        <Border Background="#FF8800" Height="60" VerticalAlignment="Top" CornerRadius="0,0,20,20">
            <TextBlock Text="Registro de Productos" Foreground="White" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
        </Border>
        <StackPanel Margin="40,80,40,40" Background="White" VerticalAlignment="Top">
            <Label Content="Nombre Producto" Foreground="#FF8800" FontWeight="Bold"/>
            <TextBox x:Name="txtNombre" Margin="0,0,0,10" Height="30"/>
            <Label Content="Código" Foreground="#FF8800" FontWeight="Bold"/>
            <TextBox x:Name="txtCodigo" Margin="0,0,0,10" Height="30"/>
            <Label Content="Descripción" Foreground="#FF8800" FontWeight="Bold"/>
            <TextBox x:Name="txtDescripcion" Margin="0,0,0,10" Height="30"/>
            <Button Content="Registrar" Background="#FF8800" Foreground="White" Height="35" Margin="0,20,0,0" Click="BtnRegistrar_Click"/>
            <Button Content="Volver" Background="White" Foreground="#FF8800" BorderBrush="#FF8800" BorderThickness="2" Height="35" Margin="0,10,0,0" Click="BtnVolver_Click"/>
        </StackPanel>
    </Grid>
</Window>