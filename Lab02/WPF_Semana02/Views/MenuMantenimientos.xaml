<Window x:Class="WPF_Semana02.Views.MenuMantenimientos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mantenimientos" Height="350" Width="400">
    <Grid Background="White">
        <Border Background="#FF8800" Height="50" VerticalAlignment="Top" CornerRadius="0,0,20,20">
            <TextBlock Text="Mantenimientos" Foreground="White" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
        </Border>
        <StackPanel Margin="40,70,40,40" Background="White" VerticalAlignment="Top">
            <Button Content="Conductores" Background="#FF8800" Foreground="White" Height="35" FontSize="14" Margin="0,0,0,10" Click="BtnConductores_Click"/>
            <Button Content="Transportistas" Background="#FF8800" Foreground="White" Height="35" FontSize="14" Margin="0,0,0,10" Click="BtnTransportistas_Click"/>
            <Button Content="Camiones" Background="#FF8800" Foreground="White" Height="35" FontSize="14" Margin="0,0,0,10" Click="BtnCamiones_Click"/>
            <Button Content="Productos" Background="#FF8800" Foreground="White" Height="35" FontSize="14" Click="BtnProductos_Click"/>
            <Button Content="Volver" Background="White" Foreground="#FF8800" BorderBrush="#FF8800" BorderThickness="2" Height="35" Margin="0,20,0,0" Click="BtnVolver_Click"/>
        </StackPanel>
    </Grid>
</Window>