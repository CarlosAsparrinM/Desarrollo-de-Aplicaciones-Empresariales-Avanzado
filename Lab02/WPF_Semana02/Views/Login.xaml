<Window x:Class="WPF_Semana02.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Semana02.Views"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800">
    <Grid Background="White">
        <Border Background="#FF8800" Height="70" VerticalAlignment="Top" CornerRadius="0,0,20,20">
            <TextBlock Text="Iniciar Sesión" Foreground="White" FontSize="28" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
        </Border>
        <StackPanel Margin="40,100,40,40" Background="White" VerticalAlignment="Top">
            <Label Content="Usuario" Foreground="#FF8800" FontWeight="Bold"/>
            <TextBox x:Name="txtUsuario" Height="30"/>
            <Label Content="Contraseña" Foreground="#FF8800" FontWeight="Bold"/>
            <PasswordBox x:Name="txtPassword" Height="30"/>
            <Button Content="Ingresar" Background="#FF8800" Foreground="White" Height="40" FontSize="16" Margin="0,20,0,0" Click="BtnIngresar_Click"/>
        </StackPanel>
    </Grid>
</Window>
