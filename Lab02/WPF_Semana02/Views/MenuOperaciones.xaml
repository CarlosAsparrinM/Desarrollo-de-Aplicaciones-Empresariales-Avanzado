<Window x:Class="WPF_Semana02.Views.MenuOperaciones"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Operaciones" Height="300" Width="400">
    <Grid Background="White">
        <Border Background="#FF8800" Height="50" VerticalAlignment="Top" CornerRadius="0,0,20,20">
            <TextBlock Text="Operaciones" Foreground="White" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
        </Border>
        <StackPanel Margin="40,70,40,40" Background="White" VerticalAlignment="Top">
            <Button Content="Ingresos" Background="#FF8800" Foreground="White" Height="35" FontSize="14" Margin="0,0,0,10" Click="BtnIngresos_Click"/>
            <Button Content="Salidas" Background="#FF8800" Foreground="White" Height="35" FontSize="14" Click="BtnSalidas_Click"/>
            <Button Content="Volver" Background="White" Foreground="#FF8800" BorderBrush="#FF8800" BorderThickness="2" Height="35" Margin="0,20,0,0" Click="BtnVolver_Click"/>
        </StackPanel>
    </Grid>
</Window>