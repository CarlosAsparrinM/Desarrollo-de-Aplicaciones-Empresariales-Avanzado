<Window x:Class="WPF_Semana02.Views.Conductores"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Semana02.Views"
        mc:Ignorable="d"
        Title="Conductores" Height="450" Width="800">
    <Grid Background="White">
        <Border Background="#FF8800" Height="60" VerticalAlignment="Top" CornerRadius="0,0,20,20">
            <TextBlock Text="Registro de Conductores" Foreground="White" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
        </Border>
        <StackPanel Margin="40,80,40,0" Background="White" VerticalAlignment="Top">
            <Label Content="Nombre Conductor" Foreground="#FF8800" FontWeight="Bold"/>
            <TextBox x:Name="txtNombre" Height="30"/>
            <Label Content="Licencia" Foreground="#FF8800" FontWeight="Bold"/>
            <TextBox x:Name="txtLicencia" Height="30"/>
            <Label Content="Transporte" Foreground="#FF8800" FontWeight="Bold"/>
            <TextBox x:Name="txtTransporte" Height="30"/>
            <Button Content="Registrar" Background="#FF8800" Foreground="White" Height="35" Margin="0,20,0,10" Click="BtnRegistrar_Click"/>
            <Button Content="Volver" Background="White" Foreground="#FF8800" BorderBrush="#FF8800" BorderThickness="2" Height="35" Click="BtnVolver_Click"/>
        </StackPanel>
        <DataGrid x:Name="dgConductores" Margin="40,320,40,40" AutoGenerateColumns="False" HeadersVisibility="Column" RowBackground="White" AlternatingRowBackground="#FFF3E0" GridLinesVisibility="None" VerticalAlignment="Top" Height="180">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nombre Conductor" Binding="{Binding Nombre}"/>
                <DataGridTextColumn Header="Licencia" Binding="{Binding Licencia}"/>
                <DataGridTextColumn Header="Transporte" Binding="{Binding Transporte}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
