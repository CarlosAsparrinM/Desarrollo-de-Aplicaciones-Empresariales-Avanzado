<Window x:Class="Lab02.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab02"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Content="Button 1" Background="Red" Margin="10" Width="245"/>
                <Button Content="Button 2" Background="Green" Margin="10" Width="245"/>
                <Button Content="Button 3" Background="Yellow" Margin="10" Width="245"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Content="Button 1" Background="Red" Margin="10" Width="245"/>
                <Button Content="Button 2" Background="Green" Margin="10" Width="245"/>
                <Button Content="Button 3" Background="Yellow" Margin="10" Width="245"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Content="Button 1" Background="Red" Margin="10" Width="245"/>
                <Button Content="Button 2" Background="Green" Margin="10" Width="245"/>
                <Button Content="Button 3" Background="Yellow" Margin="10" Width="245"/>
            </StackPanel>
            <Button Content="Button 3" Margin="10"/>
            <Button Content="Button 1" Margin="10"/>
            <Button Content="Button 2" Margin="10"/>
            <Button Content="Button 3" Margin="10"/>
        </StackPanel>

    </Grid>
</Window>
