<Window x:Class="Lab02.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab02"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Content="Button 1" Background="Red" Margin="10"
                Width="200" Grid.Column="0" Grid.Row="0"/>
        <Button Content="Button 1" Background="Blue" Margin="10"
                Width="200" Grid.Column="1" Grid.Row="0"/>
        <Button Content="Button 1" Background="Green" Margin="10"
                Width="200" Grid.Column="2" Grid.Row="0"/>
        
        <Button Content="Button 1" Background="Red" Margin="10" 
                Width="200" Grid.Column="0" Grid.Row="1"/>
        <Button Content="Button 1" Background="Blue" Margin="10"
                Width="200" Grid.Column="1" Grid.Row="1"/>
        <Button Content="Button 1" Background="Green" Margin="10"
                Width="200" Grid.Column="2" Grid.Row="1"/>

        <Button Content="Button 1" Background="Red" Margin="10"
                Width="200" Grid.Column="0" Grid.Row="2"/>
        <Button Content="Button 1" Background="Blue" Margin="10"
                Width="200" Grid.Column="1" Grid.Row="2"/>
        <Button Content="Button 1" Background="Green" Margin="10"
                Width="200" Grid.Column="2" Grid.Row="2"/>
    </Grid>
</Window>
