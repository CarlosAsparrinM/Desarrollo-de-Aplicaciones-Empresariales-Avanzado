<Window x:Class="Lab03.Productos.VistaProductosFiltro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab03.Productos"
        mc:Ignorable="d"
        Title="VistaProductosFiltro" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="10">
            <TextBox Name="txtMin" Height="25" Margin="0,0,0,5" />
            <TextBox Name="txtMax" Height="25" Margin="0,0,0,10" />

            <Button Content="Buscar por rango" Click="Buscar_Click" Height="30"/>

            <ListBox Name="lstResultado" Margin="0,10,0,0"/>
        </StackPanel>

        <Button Content="Volver al menú"
                Grid.Row="1"
                Height="35"
                Margin="10"
                Click="Volver_Click"/>
    </Grid>
</Window>
