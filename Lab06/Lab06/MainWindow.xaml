<Window x:Class="Lab06.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab06"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- MENÚ -->
        <StackPanel Background="#2C3E50">

            <Button Content="Listar Clientes"
                    Margin="10"
                    Height="40"
                    Click="BtnListar_Click"/>

            <Button Content="Registrar Cliente"
                    Margin="10"
                    Height="40"
                    Click="BtnRegistrar_Click"/>

            <Button Content="Volver"
                    Margin="10"
                    Height="40"
                    Click="BtnVolver_Click"/>
        </StackPanel>

        <!-- CONTENIDO -->
        <Frame x:Name="frameContenido"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
