<Page x:Class="Lab06.RegistrarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lab06"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistrarPage">

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- FILAS INPUT -->
                <StackPanel Grid.Row="0" Margin="5">
                    <TextBlock Text="ID Cliente"/>
                    <TextBox x:Name="txtId"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                    <TextBlock Text="Nombre Compañia"/>
                    <TextBox x:Name="txtCompania"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="5">
                    <TextBlock Text="Nombre Contacto"/>
                    <TextBox x:Name="txtContacto"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                    <TextBlock Text="Cargo"/>
                    <TextBox x:Name="txtCargo"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="5">
                    <TextBlock Text="Dirección"/>
                    <TextBox x:Name="txtDireccion"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" Margin="5">
                    <TextBlock Text="Ciudad"/>
                    <TextBox x:Name="txtCiudad"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="5">
                    <TextBlock Text="Región"/>
                    <TextBox x:Name="txtRegion"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="1" Margin="5">
                    <TextBlock Text="Cod Postal"/>
                    <TextBox x:Name="txtPostal"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="5">
                    <TextBlock Text="País"/>
                    <TextBox x:Name="txtPais"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="1" Margin="5">
                    <TextBlock Text="Teléfono"/>
                    <TextBox x:Name="txtTelefono"/>
                </StackPanel>

                <StackPanel Grid.Row="5" Margin="5">
                    <TextBlock Text="Fax"/>
                    <TextBox x:Name="txtFax"/>
                </StackPanel>

            </Grid>

            <!-- BOTÓN REGISTRAR -->
            <Button Content="Registrar"
                    Height="40"
                    Margin="10"
                    Background="#4CAF50"
                    Foreground="White"
                    Click="Registrar_Click"/>

            <!-- BOTÓN ELIMINAR -->
            <Button x:Name="btnEliminar"
                    Content="Eliminar"
                    Visibility="Collapsed"
                    Click="Eliminar_Click"
                    Margin="0,10,0,0"/>

            <!-- ✔ ÚNICO DATAGRID (CORRECTO) -->
            <DataGrid x:Name="dgMini"
                      Height="200"
                      AutoGenerateColumns="True"
                      SelectionChanged="dgMini_SelectionChanged"
                      AutoGeneratingColumn="dgMini_AutoGeneratingColumn"/>

        </StackPanel>
    </ScrollViewer>

</Page>