<Window x:Class="Lab04.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab04"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Border Background="White" CornerRadius="10" Padding="20" Margin="40">
            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="Sistema de Proveedores"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Button Content="📋 Listar Proveedores"
                        Height="40"
                        Margin="0,10"
                        Background="#3498DB"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnListar_Click"/>

                <Button Content="🔍 Buscar Proveedores"
                        Height="40"
                        Margin="0,10"
                        Background="#2ECC71"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnBuscar_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
