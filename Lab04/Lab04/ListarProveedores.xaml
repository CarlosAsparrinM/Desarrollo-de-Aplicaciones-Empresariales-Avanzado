<Window x:Class="Lab04.ListarProveedores"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab04"
        mc:Ignorable="d"
        Title="ListarProveedores" Height="450" Width="800">
    <Grid>
        <Border Background="White" CornerRadius="10" Padding="15" Margin="20">
            <StackPanel>

                <!-- Título -->
                <TextBlock Text="Listado de Proveedores"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,10"/>

                <!-- Línea decorativa -->
                <Rectangle Height="2" Fill="#3498DB" Margin="0,0,0,10"/>

                <!-- DataGrid -->
                <DataGrid x:Name="dgProveedores"
                          AutoGenerateColumns="True"
                          RowBackground="#ECF0F1"
                          AlternatingRowBackground="White"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          FontSize="14"/>

                <Button Content="⬅ Volver"
                        Width="120"
                        Margin="0,10,0,0"
                        Background="#E74C3C"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="Volver_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
